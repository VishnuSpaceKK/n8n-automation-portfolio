    {
      "parameters": {
        "jsCode": "const text = $input.first().json.message.text;\nconst matches = [...text.matchAll(/\\d+(\\.\\d+)?/g)];\nif (matches.length === 0) {\n  return {\n    json: {\n      isExpense: false,\n      reply: \"This is an expense tracker bot — share your expenses here, e.g. '500 lunch' or '200 taxi 150 coffee'.\"\n    }\n  };\n}\n\nconst expenses = [];\n\nfor (let i = 0; i < matches.length; i++) {\n  const amount = parseFloat(matches[i][0]);\n\n  const currentStart = matches[i].index;\n  const currentEnd = currentStart + matches[i][0].length;\n\n  const prevEnd = i > 0\n    ? matches[i - 1].index + matches[i - 1][0].length\n    : 0;\n\n  const nextStart = i < matches.length - 1\n    ? matches[i + 1].index\n    : text.length;\n\n  // Text before the number\n  const before = text.slice(prevEnd, currentStart).trim();\n\n  // Text after the number\n  const after = text.slice(currentEnd, nextStart).trim();\n\n  // If there's text after the amount, use it.\n  // Otherwise use the text before it.\n  const description = after || before;\n\n  expenses.push({\n    amount,\n    description,\n  });\n}\n\n// Return one item per expense\nreturn expenses.map(expense => ({\n  json: {\n    isExpense: true,\n    expense: expense,\n        }\n}));"
      },
