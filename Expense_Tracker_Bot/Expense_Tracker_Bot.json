    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst oneWeekAgo = new Date();\noneWeekAgo.setDate(oneWeekAgo.getDate() - 7);\n\nconst totals = {};\n\nfor (const row of rows) {\n  const rowDate = new Date(row.json.timestamp);\n\n  // Skip expenses older than one week\n  if (rowDate < oneWeekAgo) {\n    continue;\n  }\n\n  const chatId = row.json.chat_id;\n  const amount = parseFloat(row.json.amount) || 0;\n  const description = row.json.description || \"\";\n\n  // Initialize user if not seen before\n  if (!totals[chatId]) {\n    totals[chatId] = {\n      total: 0,\n      items: [],\n    };\n  }\n\n  // Update total\n  totals[chatId].total += amount;\n\n  // Save expense summary\n  totals[chatId].items.push(`${amount} - ${description}`);\n}\n\n// Convert grouped object into n8n items\nreturn Object.entries(totals).map(([chatId, data]) => ({\n  json: {\n    chat_id: chatId,\n    total: data.total,\n    summary: data.items.join(\", \"),\n  },\n}));"
      },
